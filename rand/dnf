dnf update --exclude="selinux-policy*,lvm2*,device-mapper*"


setenforce 0
dnf update
setenforce 1
# Then touch /.autorelabel && reboot to clean up labels
touch /.autorelabel
reboot


# Rebuild DB first
rm -f /var/lib/rpm/__db.*
rpm --rebuilddb

# Verify no broken packages
dnf check
dnf repoquery --duplicates

# Then update with reduced parallelism to keep I/O flatter
dnf update --setopt=max_parallel_downloads=1 --setopt=deltarpm=false


In the vSphere client:
Right-click the VM → Edit Settings
VM Options tab → VMware Tools section
VM Monitoring → change to Disabled
Click OK




